{
  "name": "countless-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Countless — privacy-first, Cloudflare-native web analytics.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "wrangler dev",
    "dev:web": "pnpm --filter @countless/dashboard dev",
    "dev:worker": "pnpm --filter @countless/server dev",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "ci": "biome ci .",
    "build": "pnpm --filter @countless/dashboard build && pnpm -r --filter '!@countless/dashboard' build",
    "deploy": "pnpm --filter @countless/server deploy",
    "db:generate": "pnpm --filter @countless/server db:generate",
    "db:migrate": "pnpm --filter @countless/server migrate:local"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@cloudflare/workers-types": "4.20250712.0",
    "typescript": "5.7.3",
    "wrangler": "4.0.0"
  }
}