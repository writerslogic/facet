{
  "name": "facet",
  "version": "0.3.0",
  "private": true,
  "description": "Facet — privacy-first, Cloudflare-native web analytics.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "wrangler dev",
    "dev:web": "pnpm --filter @facet/dashboard dev",
    "dev:worker": "pnpm --filter @facet/server dev",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --workspace-concurrency=1 test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "check:links": "node scripts/check-release-links.mjs",
    "format": "biome format --write .",
    "ci": "biome ci .",
    "build": "pnpm --filter @facet/dashboard build && pnpm -r --filter '!@facet/dashboard' build",
    "deploy": "pnpm --filter @facet/server deploy",
    "db:generate": "pnpm --filter @facet/server db:generate",
    "db:migrate": "pnpm --filter @facet/server migrate:local"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@cloudflare/workers-types": "4.20250712.0",
    "typescript": "5.7.3",
    "wrangler": "4.0.0"
  }
}