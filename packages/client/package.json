{
	"name": "countless",
	"version": "0.1.0",
	"description": "Countless browser tracking snippet: zero-dependency, umami-compatible.",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": ["dist"],
	"sideEffects": ["./dist/auto.js"],
	"scripts": {
		"build": "tsup src/index.ts src/auto.ts --format esm --dts --minify",
		"lint": "biome check .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --passWithNoTests"
	},
	"devDependencies": {
		"@countless/shared": "workspace:*",
		"tsup": "8.3.5",
		"typescript": "5.7.3",
		"vitest": "2.1.8"
	}
}
