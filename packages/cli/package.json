{
	"name": "@writerslogic/facet-cli",
	"version": "0.3.0",
	"description": "Facet CLI: init, migrate, and stats for self-hosted Facet.",
	"license": "MIT",
	"type": "module",
	"bin": {
		"facet": "./dist/index.js"
	},
	"files": ["dist"],
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts",
		"dev": "tsx src/index.ts",
		"lint": "biome check .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --passWithNoTests"
	},
	"dependencies": {
		"@clack/prompts": "0.11.0",
		"@facet/shared": "workspace:*",
		"picocolors": "1.1.1"
	},
	"devDependencies": {
		"@types/node": "22.20.1",
		"tsup": "8.5.1",
		"tsx": "4.23.1",
		"typescript": "5.9.3",
		"vitest": "2.1.9"
	}
}
