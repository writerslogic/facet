{
	"name": "@writerslogic/facet",
	"version": "0.3.0",
	"description": "Facet browser tracking snippet: zero-dependency, umami-compatible.",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": ["dist"],
	"sideEffects": ["./dist/auto.js"],
	"scripts": {
		"build": "tsup",
		"lint": "biome check .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --passWithNoTests"
	},
	"devDependencies": {
		"@facet/shared": "workspace:*",
		"tsup": "8.5.1",
		"typescript": "5.9.3",
		"vitest": "2.1.9"
	}
}
