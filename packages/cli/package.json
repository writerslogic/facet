{
	"name": "@writerslogic/facet-cli",
	"version": "0.3.0",
	"description": "Facet CLI: init, migrate, and stats for self-hosted Facet.",
	"license": "MIT",
	"type": "module",
	"bin": {
		"facet": "./dist/index.js"
	},
	"files": ["dist"],
	"scripts": {
		"build": "tsup",
		"dev": "tsx src/index.ts",
		"lint": "biome check .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --passWithNoTests",
		"check:package": "publint"
	},
	"dependencies": {
		"@clack/prompts": "0.9.1",
		"@facet/shared": "workspace:*",
		"@facet/trust": "workspace:*",
		"picocolors": "1.1.1"
	},
	"devDependencies": {
		"@types/node": "22.10.5",
		"publint": "0.3.5",
		"tsup": "8.3.5",
		"tsx": "4.19.2",
		"typescript": "5.7.3",
		"vitest": "2.1.8"
	}
}
