{
	"name": "@facet/server",
	"version": "0.0.0",
	"private": true,
	"description": "Facet Cloudflare Worker: ingest, stats API, cron rollups, and D1 schema.",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"dev": "wrangler dev",
		"deploy": "wrangler deploy --minify",
		"lint": "biome check .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"gen:test-config": "node scripts/gen-test-wrangler.mjs",
		"pretest": "node scripts/gen-test-wrangler.mjs && pnpm --filter @facet/dashboard build",
		"test": "vitest run",
		"db:generate": "drizzle-kit generate",
		"migrate:local": "wrangler d1 migrations apply facet --local",
		"migrate:remote": "wrangler d1 migrations apply facet --remote",
		"seed:local": "wrangler d1 execute facet --local --file=./scripts/seed.sql"
	},
	"dependencies": {
		"@facet/shared": "workspace:*",
		"@hono/valibot-validator": "0.5.2",
		"drizzle-orm": "0.38.3",
		"hono": "4.6.14",
		"isbot": "5.1.28",
		"valibot": "1.0.0"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "0.6.4",
		"@cloudflare/workers-types": "4.20250712.0",
		"drizzle-kit": "0.30.1",
		"typescript": "5.7.3",
		"vitest": "2.1.8",
		"wrangler": "4.0.0"
	}
}
