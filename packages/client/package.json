{
	"name": "@writerslogic/facet",
	"version": "0.5.2",
	"description": "Facet browser tracking snippet: zero-dependency, umami-compatible.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/writerslogic/facet.git",
		"directory": "packages/client"
	},
	"homepage": "https://github.com/writerslogic/facet#readme",
	"bugs": "https://github.com/writerslogic/facet/issues",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": ["dist"],
	"sideEffects": ["./dist/auto.js"],
	"scripts": {
		"build": "tsup",
		"lint": "biome check .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --passWithNoTests",
		"check:package": "publint && attw --pack . --ignore-rules cjs-resolves-to-esm"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "0.18.5",
		"@facet/shared": "workspace:*",
		"publint": "0.3.21",
		"tsup": "8.5.1",
		"typescript": "5.9.3",
		"vitest": "4.1.10"
	}
}
